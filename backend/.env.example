# Backend runtime
APP_ENV=production
STORAGE_ROOT=d:/Workspace/viewr_ct/data
MAX_WORKERS=4

# Public surface
API_DOCS_ENABLED=false
HEALTH_DETAILS_ENABLED=false
SECURITY_HEADERS_ENABLED=true

# Browser access
# Comma-separated or JSON array. Do not use * in production.
CORS_ORIGINS=https://viewer.example.com
CORS_ALLOW_CREDENTIALS=false
TRUSTED_HOSTS=api.example.com

# Distributed runtime
DISTRIBUTED_RUNTIME_MODE=auto
# REDIS_URL=redis://localhost:6379/0
# REDIS_KEY_PREFIX=viewr_ct:
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET=
# R2_PUBLIC_BASE_URL=
